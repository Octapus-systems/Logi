# Logi App Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/logi?retryWrites=true&w=majority

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Lives System Cron Job Protection (optional but recommended)
# Set this to protect the /api/v1/lives/cron endpoint from unauthorized access
CRON_SECRET=your-cron-secret-here
